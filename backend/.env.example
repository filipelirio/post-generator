PROJECT_NAME="Easy Artigos"
API_V1_STR="/api/v1"

# O backend usa backend/data por padrao.
# So defina os caminhos abaixo se quiser sobrescrever a convencao atual.
# DATABASE_URL=
# EXCEL_PAUTAS_PATH=
# GENERATED_ARTICLES_DIR=
# GENERATED_IMAGES_DIR=

OPENAI_API_KEY="COLOQUE_SUA_CHAVE_AQUI"
OPENAI_MODEL="gpt-5"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_IMAGE_SIZE="1536x1024"
OPENAI_IMAGE_QUALITY="medium"
OPENAI_WEBSEARCH_ENABLED="true"

WORDPRESS_URL="https://easymedicina.com"
WORDPRESS_USERNAME="seu_usuario"
WORDPRESS_APPLICATION_PASSWORD="xxxx xxxx xxxx xxxx xxxx"
DEFAULT_POST_STATUS="draft"

LOG_LEVEL="INFO"
