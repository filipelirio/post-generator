# ---- CONFIGURAÇÕES GERAIS ----
PROJECT_NAME="Gerador de Artigos AI"
API_V1_STR="/api/v1"

# ---- BANCO DE DADOS ----
# SQLite para MVP local
DATABASE_URL="sqlite:///./sql_app.db"

# ---- GEMINI API (GOOGLE AI STUDIO) ----
GEMINI_API_KEY="COLOQUE_SUA_CHAVE_AQUI"
GEMINI_MODEL="gemini-2.5-pro" # Recomendado para tarefas complexas como redação de artigos

# ---- WORDPRESS INTEGRAÇÃO ----
WORDPRESS_URL="https://easymedicina.com"
WORDPRESS_USERNAME="seu_usuario"
# Application Password (gerado no perfil do usuário no WP)
WORDPRESS_APPLICATION_PASSWORD="xxxx xxxx xxxx xxxx xxxx"
DEFAULT_POST_STATUS="draft" # draft ou publish

# ---- OUTROS ----
LOG_LEVEL="INFO"
